<section id="contact" class="section-pad">
  <div class="wrap">
    <div class="relative overflow-hidden rounded-xl3 bg-ink px-8 py-16 text-center sm:px-16 sm:py-20 reveal">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute -top-24 left-1/2 h-64 w-[36rem] -translate-x-1/2 rounded-full bg-accent-500/30 blur-[90px]"></div>
      </div>

      <div class="relative">
        <span class="eyebrow !text-accent-300">Let's build</span>
        <h2 class="mx-auto mt-4 max-w-2xl text-display-lg font-display font-bold text-white">
          Have an app idea? Let's scope it in 30 minutes.
        </h2>
        <p class="mx-auto mt-4 max-w-lg text-lg text-white/70">
          No slide deck, no sales pressure — just a conversation about what you're building and whether we're the right team for
          it.
        </p>

        <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
          <a href="mailto:hello@dubtek.io" class="btn bg-white text-ink hover:-translate-y-0.5 hover:shadow-lift">
            Book a free consultation
          </a>
          <a href="#projects" class="btn border border-white/20 text-white hover:-translate-y-0.5 hover:border-white/40">
            See our work first
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
