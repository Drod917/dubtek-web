---
const faqs = [
  {
    q: "How much does it cost to build an app?",
    a: "Most projects fall between $15,000 and $80,000 depending on scope, platforms, and backend complexity. After discovery, we give you a fixed quote — not a range — so you can budget with confidence.",
  },
  {
    q: "How long does a typical build take?",
    a: "A focused MVP usually takes 8–12 weeks. Larger products with custom backends or multiple platforms run 4–6 months. You'll get a working build to test every two weeks.",
  },
  {
    q: "Who owns the code and design files when we're done?",
    a: "You do, fully. Source code, design files, and credentials are handed over at project close with no licensing strings attached.",
  },
  {
    q: "Do you offer ongoing maintenance after launch?",
    a: "Yes. Every project can move into a monthly support plan covering OS updates, bug fixes, and new device compatibility — priced separately from the build.",
  },
  {
    q: "Which platforms do you build for?",
    a: "Native iOS (Swift) and Android (Kotlin), plus cross-platform apps in Flutter or React Native when a shared codebase makes sense for your budget and timeline.",
  },
  {
    q: "Will you publish the app to the App Store and Play Store for us?",
    a: "Yes — we manage developer accounts, provisioning, store listings, and the submission process itself, so launch day doesn't depend on you learning Apple and Google's review systems.",
  },
];
---

<section id="faq" class="section-pad bg-surface-raised">
  <div class="wrap max-w-3xl">
    <div class="reveal">
      <span class="eyebrow">FAQ</span>
      <h2 class="mt-4 text-display-lg font-display font-bold">Questions founders ask us first.</h2>
    </div>

    <div class="mt-12 divide-y divide-surface-border rounded-xl2 border border-surface-border bg-white reveal">
      {
        faqs.map((f) => (
          <details class="group px-6 py-5 open:bg-surface-raised/40 sm:px-7">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-display text-[0.95rem] font-semibold text-ink marker:content-none">
              {f.q}
              <svg
                width="18" height="18" viewBox="0 0 18 18" fill="none"
                class="shrink-0 text-ink-faint transition-transform duration-300 group-open:rotate-45"
              >
                <path d="M9 3v12M3 9h12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              </svg>
            </summary>
            <p class="mt-3 max-w-xl text-sm leading-relaxed text-ink-soft">{f.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
