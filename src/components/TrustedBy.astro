---
const companies = ["Northwind", "Fernway", "Loopline", "Basecamp Labs", "Verdant", "Haloform"];
---

<section class="border-y border-surface-border bg-surface-raised/60 py-10">
  <div class="wrap">
    <p class="text-center font-mono text-[0.7rem] uppercase tracking-[0.16em] text-ink-faint">
      Trusted by product teams at
    </p>
    <div class="mt-7 grid grid-cols-2 gap-x-8 gap-y-6 opacity-70 sm:grid-cols-3 lg:grid-cols-6">
      {
        companies.map((name) => (
          <div class="flex items-center justify-center">
            <span class="select-none font-display text-lg font-bold tracking-tight text-ink-faint grayscale transition hover:text-ink hover:grayscale-0">
              {name}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>
