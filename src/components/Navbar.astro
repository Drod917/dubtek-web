---
const links = [
  { href: "#services", label: "Services" },
  { href: "#process", label: "Process" },
  { href: "#work", label: "Work" },
  { href: "#faq", label: "FAQ" },
];
---

<header class="sticky top-0 z-50 border-b border-transparent">
  <div id="navbar-inner" class="transition-all duration-300">
    <nav class="wrap flex h-16 items-center justify-between">
      <a href="#top" class="flex items-center gap-2 font-display text-[1.05rem] font-bold tracking-tight text-ink">
        <span class="relative flex h-7 w-7 items-center justify-center rounded-lg bg-ink">
          <span class="h-2.5 w-2.5 rounded-full bg-gradient-to-br from-accent-400 to-accent-600"></span>
        </span>
        Dubtek
      </a>

      <ul class="hidden items-center gap-8 md:flex">
        {
          links.map((link) => (
            <li>
              <a href={link.href} class="text-sm font-medium text-ink-soft transition-colors hover:text-ink">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="flex items-center gap-3">
        <a href="#contact" class="btn-primary hidden sm:inline-flex text-sm !px-5 !py-2.5"> Book a consultation </a>
        <a href="#contact" class="btn-primary sm:hidden text-sm !px-4 !py-2">Talk to us</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const inner = document.getElementById("navbar-inner");
  const onScroll = () => {
    if (!inner) return;
    if (window.scrollY > 8) {
      inner.classList.add("bg-white/80", "backdrop-blur-md", "shadow-soft", "border-b", "border-surface-border");
    } else {
      inner.classList.remove("bg-white/80", "backdrop-blur-md", "shadow-soft", "border-b", "border-surface-border");
    }
  };
  document.addEventListener("scroll", onScroll, { passive: true });
  onScroll();
</script>
