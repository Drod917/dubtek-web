---
const services = [
  {
    title: "iOS development",
    outcome: "Launch on the App Store with an app that feels native, not bolted-on.",
    detail: "Swift and SwiftUI builds tuned for performance and Apple's review guidelines, so you avoid rejections and delays.",
    icon: "apple",
  },
  {
    title: "Android development",
    outcome: "Reach the widest possible audience across every device tier.",
    detail: "Kotlin-based apps built to Material Design standards and tested across the fragmented Android ecosystem.",
    icon: "android",
  },
  {
    title: "Flutter development",
    outcome: "Ship to iOS and Android from one codebase, without compromising on feel.",
    detail: "A single investment that halves your maintenance surface while keeping platform-native performance.",
    icon: "layers",
  },
  {
    title: "React Native development",
    outcome: "Move fast with a stack your web team can also read and extend.",
    detail: "Ideal when you already have JavaScript expertise in-house and want to keep hiring simple.",
    icon: "react",
  },
  {
    title: "UI/UX design",
    outcome: "Turn a rough idea into a product people enjoy opening every day.",
    detail: "Research, wireframes, and pixel-perfect prototypes validated with real users before a line of code is written.",
    icon: "figma",
  },
  {
    title: "Backend & API integration",
    outcome: "Give your app a foundation that scales past your first 10,000 users.",
    detail: "Secure REST and GraphQL APIs, third-party integrations, and Firebase setups built for real growth.",
    icon: "api",
  },
  {
    title: "App Store deployment",
    outcome: "Skip the submission headaches and get to launch day faster.",
    detail: "We manage provisioning, store listings, screenshots, and compliance for both Apple and Google.",
    icon: "rocket",
  },
  {
    title: "Maintenance & support",
    outcome: "Keep your app fast, secure, and compatible with every new OS release.",
    detail: "Ongoing monitoring, updates, and a direct line to the team that built it — no ticket queues.",
    icon: "shield",
  },
];

const icons: Record<string, string> = {
  apple: `<path d="M16.5 8.4c-1.5-1.7-3.7-1.6-4.6-1.6-.9 0-2.6-.1-4 .8-1.5.9-2.6 2.6-2.6 5.1 0 3 1.8 6.5 3.3 8.1.8.9 1.7 1.9 2.9 1.9 1.1 0 1.5-.7 2.9-.7s1.7.7 2.9.7c1.2 0 2-.9 2.8-1.9.6-.8 1.2-1.9 1.5-3-2.9-1-3.5-4.9-1.1-6.4-1-1.4-2.5-2.1-4-2Z"/><path d="M13.8 5.4c.6-.8 1-1.9.9-3-.9.1-2 .6-2.6 1.4-.6.7-1.1 1.8-.9 2.9 1 .1 2-.5 2.6-1.3Z"/>`,
  android: `<path d="M6 10.5V17a1 1 0 001 1h1v3a1 1 0 002 0v-3h4v3a1 1 0 002 0v-3h1a1 1 0 001-1v-6.5H6Z"/><circle cx="9" cy="7" r="1"/><circle cx="15" cy="7" r="1"/><path d="M7 9.5C7 6.5 9.7 4 13 4s6 2.5 6 5.5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/><path d="m8 4.5-1-1.5M16 4.5l1-1.5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>`,
  layers: `<path d="M12 3 3 8l9 5 9-5-9-5Z"/><path d="m3 13 9 5 9-5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/><path d="m3 17.5 9 5 9-5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>`,
  react: `<circle cx="12" cy="12" r="2.2"/><ellipse cx="12" cy="12" rx="9" ry="3.6" stroke="currentColor" stroke-width="1.4" fill="none"/><ellipse cx="12" cy="12" rx="9" ry="3.6" stroke="currentColor" stroke-width="1.4" fill="none" transform="rotate(60 12 12)"/><ellipse cx="12" cy="12" rx="9" ry="3.6" stroke="currentColor" stroke-width="1.4" fill="none" transform="rotate(120 12 12)"/>`,
  figma: `<path d="M9 2h4a3 3 0 010 6H9V2Z"/><path d="M9 8h4a3 3 0 010 6H9V8Z" opacity=".7"/><path d="M9 14h4a3 3 0 010 6H9v-6Z" opacity=".45"/><circle cx="9" cy="17" r="3"/>`,
  api: `<rect x="3" y="4" width="18" height="16" rx="3" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M8 9h8M8 13h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  rocket: `<path d="M12 2c3 1.5 5 5 5 9 0 2-.6 3.6-1.4 4.9L12 19l-3.6-3.1C7.6 14.6 7 13 7 11c0-4 2-7.5 5-9Z" stroke="currentColor" stroke-width="1.4" fill="none"/><circle cx="12" cy="10" r="1.6"/><path d="M9 17.5 7 21M15 17.5l2 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>`,
  shield: `<path d="M12 3l7 3v6c0 4.5-3 7.7-7 9-4-1.3-7-4.5-7-9V6l7-3Z" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>`,
};
---

<section id="services" class="section-pad">
  <div class="wrap">
    <div class="max-w-2xl reveal">
      <span class="eyebrow">Services</span>
      <h2 class="mt-4 text-display-lg font-display font-bold">
        Every discipline your app needs, under one roof.
      </h2>
      <p class="mt-4 text-lg text-ink-soft">
        We don't hand you off between vendors. One team carries your product from
        concept to the App Store — and stays on after launch.
      </p>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        services.map((s, i) => (
          <div
            class="card card-hover reveal flex flex-col p-6"
            style={`transition-delay:${(i % 4) * 60}ms`}
          >
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-accent-50 text-accent-600">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" set:html={icons[s.icon]} />
            </div>
            <h3 class="mt-5 font-display text-lg font-bold text-ink">{s.title}</h3>
            <p class="mt-2 text-[0.95rem] font-medium text-ink">{s.outcome}</p>
            <p class="mt-2 text-sm leading-relaxed text-ink-soft">{s.detail}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
