---
const platforms = ["iOS", "Android", "Flutter", "React Native"];
---

<section id="top" class="relative overflow-hidden pt-20 sm:pt-28">
  <!-- Ambient background -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-accent-radial"></div>
    <div
      class="absolute inset-0 opacity-[0.35] [background-size:22px_22px]"
      style="background-image: radial-gradient(circle, #E7E9EE 1px, transparent 1px); mask-image: linear-gradient(to bottom, black, transparent 75%);"
    >
    </div>
  </div>

  <div class="wrap grid items-center gap-16 pb-20 sm:pb-28 lg:grid-cols-[1.05fr_0.95fr] lg:gap-10">
    <!-- Copy -->
    <div class="reveal">
      <span class="eyebrow mb-6">
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
        Now booking Q3 2026 app launches
      </span>

      <h1 class="text-display-xl font-display font-extrabold text-ink">
        Beautiful mobile apps,
        <span class="bg-gradient-to-r from-accent-600 via-accent-500 to-accent-400 bg-clip-text text-transparent">
          built for growth.
        </span>
      </h1>

      <p class="mt-6 max-w-[46ch] text-lg leading-relaxed text-ink-soft">
        Dubtek designs and ships fast, reliable iOS, Android, and cross-platform apps for startups and growing businesses — from
        the first sketch to the App Store listing.
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-4">
        <a href="#contact" class="btn-primary">
          Book a free consultation
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="transition-transform group-hover:translate-x-0.5">
            <path
              d="M3.5 8H12.5M12.5 8L8.5 4M12.5 8L8.5 12"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
        <a href="#work" class="btn-secondary">View our work</a>
      </div>

      <div class="mt-12 flex items-center gap-6 text-sm text-ink-faint">
        <div class="flex -space-x-3">
          {
            ["#FDE68A", "#A7F3D0", "#BFDBFE", "#FBCFE8"].map((c) => (
              <span class="h-9 w-9 rounded-full border-2 border-white" style={`background:${c}`} />
            ))
          }
        </div>
        <p>Trusted by <span class="font-semibold text-ink">40+ founders</span> to ship their first release</p>
      </div>
    </div>

    <!-- Signature visual: layered phone mockups -->
    <div class="relative mx-auto h-[420px] w-full max-w-sm sm:h-[480px] reveal" style="transition-delay: 120ms;">
      <!-- Back phone -->
      <div
        class="absolute left-1/2 top-6 h-[360px] w-[190px] -translate-x-[78%] rounded-[2.2rem] border border-surface-border bg-white p-2 shadow-card animate-float"
        style="--tilt: -9deg; transform: rotate(-9deg); animation-delay: -1.2s;"
      >
        <div class="h-full w-full rounded-[1.7rem] bg-surface-raised p-3">
          <div class="h-2 w-10 rounded-full bg-ink/10"></div>
          <div class="mt-4 h-20 w-full rounded-xl bg-gradient-to-br from-accent-100 to-white"></div>
          <div class="mt-3 space-y-2">
            <div class="h-2 w-3/4 rounded-full bg-ink/10"></div>
            <div class="h-2 w-1/2 rounded-full bg-ink/10"></div>
          </div>
        </div>
      </div>

      <!-- Front phone -->
      <div
        class="absolute left-1/2 top-0 h-[400px] w-[210px] -translate-x-[28%] rounded-[2.4rem] border border-surface-border bg-white p-2 shadow-lift animate-float"
        style="--tilt: 6deg; transform: rotate(6deg); animation-delay: -3.6s;"
      >
        <div class="flex h-full w-full flex-col rounded-[1.9rem] bg-ink p-3">
          <div class="flex items-center justify-between px-1 pt-1">
            <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
            <span class="h-1.5 w-14 rounded-full bg-white/20"></span>
          </div>
          <div class="mt-4 flex-1 rounded-2xl bg-gradient-to-br from-accent-500 via-accent-600 to-accent-900 p-4">
            <div class="h-1.5 w-16 rounded-full bg-white/70"></div>
            <div class="mt-2 h-1.5 w-24 rounded-full bg-white/40"></div>
            <div class="mt-6 h-20 rounded-xl bg-white/10 backdrop-blur"></div>
            <div class="mt-3 grid grid-cols-3 gap-2">
              <div class="h-10 rounded-lg bg-white/10"></div>
              <div class="h-10 rounded-lg bg-white/10"></div>
              <div class="h-10 rounded-lg bg-white/10"></div>
            </div>
          </div>
          <div class="mt-3 h-9 rounded-full bg-white/95"></div>
        </div>
      </div>

      <!-- Platform pill, cycles through platforms -->
      <div
        class="absolute -bottom-2 left-1/2 -translate-x-1/2 rounded-full border border-surface-border bg-white/90 px-4 py-2 text-xs font-mono text-ink-soft shadow-soft backdrop-blur"
      >
        <span class="relative inline-grid h-4 w-24 place-items-start overflow-hidden align-middle">
          {
            platforms.map((p, i) => (
              <span
                class="col-start-1 row-start-1"
                style={`animation: pill-cycle 8s ease-in-out infinite; animation-delay: ${i * 2}s;`}
              >
                Built with {p}
              </span>
            ))
          }
        </span>
      </div>
    </div>
  </div>
</section>
